    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.2.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Kalypsis.Application\Kalypsis.Application.csproj" />
    <ProjectReference Include="..\Kalypsis.Infrastructure\Kalypsis.Infrastructure.csproj" />
  </ItemGroup>

