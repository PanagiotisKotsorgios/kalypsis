# Copy to .env and adjust — or set the same keys in Coolify's environment UI.

# --- MySQL ------------------------------------------------------------------
DB_NAME=kalypsis
DB_USER=kalypsis
DB_PASSWORD=changeMeInCoolify
DB_ROOT_PASSWORD=changeMeInCoolify_root

# --- API --------------------------------------------------------------------
# Generate a long random JWT secret with:  openssl rand -base64 48
JWT_SECRET=REPLACE-WITH-AT-LEAST-32-CHAR-SECRET-FROM-COOLIFY-UI
JWT_ISSUER=kalypsis
JWT_AUDIENCE=kalypsis-clients

# Where the SPA is served — used for CORS + email links.
PUBLIC_ORIGIN=https://kalypsis.example.com

# Optional Brevo email integration — leave empty to disable outbound mail.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@kalypsis.gr
BREVO_SENDER_NAME=Kalypsis

# --- Web --------------------------------------------------------------------
WEB_PORT=80
